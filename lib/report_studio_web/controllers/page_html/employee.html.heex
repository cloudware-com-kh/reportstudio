<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href={~p"/assets/css/employee.css"} />
    <link rel="stylesheet" href="report.css" />
    <style>
      @page { size: A4 landscape; margin: 0; }
      body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    </style>
  </head>
  <!-- Add flex-col and gap-12 here so the pages stack visually in your browser -->
  <body class="bg-slate-300 print:bg-white flex flex-col items-center py-12 gap-12 print:py-0 print:gap-0 print:block">
    <!-- Loop the PAPER wrapper, not just the content -->
    <div
      :for={employee <- @employees}
      class="w-[297mm] h-[210mm] p-[20mm] bg-white shadow-2xl print:shadow-none box-border relative break-after-page"
    >
      <h1 class="text-3xl font-bold text-red-700">Employee Dossier</h1>
      <div class="mt-8 grid grid-cols-[220px_1fr] gap-8 items-start">
        <div class="rounded-2xl bg-linear-to-br from-green-50 to-emerald-100 p-4 shadow-sm border border-green-100">
          <img
            src="https://placehold.co/600x600"
            alt={"Profile photo of #{employee.name}"}
            class="w-full aspect-square rounded-xl object-cover shadow-md"
          />
          <div class="mt-4 text-center">
            <p class="text-xl font-bold text-slate-900">{employee.name}</p>
            <p class="text-sm font-medium uppercase tracking-wide text-green-700">
              Employee Profile
            </p>
          </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-start justify-between gap-6 border-b border-slate-200 pb-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-wider text-green-700">
                Dossier Summary
              </p>
              <h2 class="mt-1 text-3xl font-bold text-slate-900">{employee.name}</h2>
            </div>
            <div class="rounded-full bg-green-100 px-4 py-2 text-sm font-semibold text-green-800">
              Active Employee
            </div>
          </div>

          <div class="mt-6 grid grid-cols-2 gap-4">
            <div class="rounded-xl bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                Full Name
              </p>
              <p class="mt-1 text-lg font-semibold text-slate-900">{employee.name}</p>
            </div>
            <div class="rounded-xl bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                Report Type
              </p>
              <p class="mt-1 text-lg font-semibold text-slate-900">Employee Dossier</p>
            </div>
            <div class="rounded-xl bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Status</p>
              <p class="mt-1 text-lg font-semibold text-green-700">Current</p>
            </div>
            <div class="rounded-xl bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                Prepared For
              </p>
              <p class="mt-1 text-lg font-semibold text-slate-900">HR Records</p>
            </div>
          </div>
        </div>
      </div>

      <!-- More complex, full-page employee data here -->
    </div>
  </body>
</html>
